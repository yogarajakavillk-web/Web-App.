import React, { useState, useEffect, useRef } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getAuth, 
  signInWithCustomToken, 
  signInAnonymously, 
  onAuthStateChanged, 
  signOut
} from 'firebase/auth';
import { 
  getFirestore, 
  collection, 
  doc, 
  addDoc, 
  onSnapshot, 
  updateDoc, 
  deleteDoc, 
  serverTimestamp 
} from 'firebase/firestore';
import { 
  MessageSquare, 
  Send, 
  Plus, 
  LogOut, 
  Search, 
  Menu, 
  X,
  Trash2,
  Cpu, 
  Zap,
  Paperclip,
  Mic,
  MicOff,
  Volume2,
  Play,
  Waves,
  Fingerprint
} from 'lucide-react';

// --- Configuration ---
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'kavil-ai-node';
const apiKey = ""; 

export default function App() {
  const [user, setUser] = useState(null);
  const [sidebarOpen, setSidebarOpen] = useState(false);
  const [searchQuery, setSearchQuery] = useState("");
  
  // Data States
  const [chats, setChats] = useState([]);
  const [activeId, setActiveId] = useState(null);
  const [messages, setMessages] = useState([]);
  
  // Input/UI States
  const [input, setInput] = useState("");
  const [loading, setLoading] = useState(false);

  // Voice States
  const [isListening, setIsListening] = useState(false);
  const [isSpeaking, setIsSpeaking] = useState(null);
  const recognitionRef = useRef(null);
  const scrollRef = useRef(null);

  // Auth Logic
  useEffect(() => {
    const initAuth = async () => {
      if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
        await signInWithCustomToken(auth, __initial_auth_token);
      } else {
        await signInAnonymously(auth);
      }
    };
    initAuth();
    return onAuthStateChanged(auth, setUser);
  }, []);

  // Fetch Sidebar Items (Chats)
  useEffect(() => {
    if (!user) return;
    const qChats = collection(db, 'artifacts', appId, 'users', user.uid, 'chats');
    const unsubChats = onSnapshot(qChats, (s) => {
      setChats(s.docs.map(d => ({id: d.id, ...d.data()})).sort((a,b) => (b.updatedAt?.seconds || 0) - (a.updatedAt?.seconds || 0)));
    }, (err) => console.error(err));

    return () => unsubChats();
  }, [user]);

  // Fetch Messages for active chat
  useEffect(() => {
    if (!user || !activeId) { setMessages([]); return; }
    const q = collection(db, 'artifacts', appId, 'users', user.uid, 'chats', activeId, 'messages');
    const unsubMsgs = onSnapshot(q, (s) => {
      const msgs = s.docs.map(d => ({id: d.id, ...d.data()})).sort((a,b) => (a.timestamp?.seconds || 0) - (b.timestamp?.seconds || 0));
      setMessages(msgs);
      setTimeout(() => scrollRef.current?.scrollIntoView({ behavior: 'smooth' }), 100);
    }, (err) => console.error(err));

    return () => unsubMsgs();
  }, [user, activeId]);

  // Voice Recognition Setup
  useEffect(() => {
    const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
    if (SpeechRecognition) {
      recognitionRef.current = new SpeechRecognition();
      recognitionRef.current.onresult = (e) => {
        const text = e.results[0][0].transcript;
        setInput(prev => prev + " " + text);
        setIsListening(false);
      };
      recognitionRef.current.onend = () => setIsListening(false);
    }
  }, []);

  // AI Logic
  const handleSendMessage = async () => {
    if (!input.trim() || !user || loading) return;
    setLoading(true);
    const text = input; setInput("");
    try {
      let chatId = activeId;
      if (!chatId) {
        const d = await addDoc(collection(db, 'artifacts', appId, 'users', user.uid, 'chats'), {
          title: text.substring(0, 30), updatedAt: serverTimestamp()
        });
        chatId = d.id; setActiveId(chatId);
      }
      
      const msgCol = collection(db, 'artifacts', appId, 'users', user.uid, 'chats', chatId, 'messages');
      await addDoc(msgCol, { text, sender: 'user', timestamp: serverTimestamp() });
      
      const response = await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ contents: [{ parts: [{ text }] }] })
      });
      const data = await response.json();
      const aiText = data.candidates?.[0]?.content?.parts?.[0]?.text || "System encounterd an error.";
      
      await addDoc(msgCol, { text: aiText, sender: 'ai', timestamp: serverTimestamp() });
      await updateDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'chats', chatId), { updatedAt: serverTimestamp() });
    } finally { setLoading(false); }
  };

  const deleteChat = async (e, id) => {
    e.stopPropagation();
    if (!user) return;
    await deleteDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'chats', id));
    if (activeId === id) setActiveId(null);
  };

  if (!user) return <div className="h-screen bg-[#020617] flex items-center justify-center font-black text-indigo-500 animate-pulse tracking-widest uppercase text-xs">Initializing Neural Link...</div>;

  return (
    <div className="flex h-screen bg-[#020617] text-slate-100 font-sans overflow-hidden">
      {/* Sidebar */}
      <aside className={`fixed inset-y-0 left-0 z-50 w-72 bg-[#0b0f1a] border-r border-slate-800/50 transition-transform lg:relative lg:translate-x-0 ${sidebarOpen ? 'translate-x-0' : '-translate-x-full'}`}>
        <div className="flex flex-col h-full p-6">
          <div className="flex items-center gap-4 mb-10">
            <div className="w-10 h-10 bg-indigo-600 rounded-xl flex items-center justify-center font-black text-white italic shadow-2xl">K</div>
            <h1 className="text-sm font-black tracking-[0.2em] uppercase">KAVIL NODE</h1>
          </div>

          <button onClick={() => { setActiveId(null); setSidebarOpen(false); }} className="w-full mb-8 py-4 bg-indigo-600 hover:bg-indigo-500 text-white rounded-2xl text-[9px] font-black uppercase tracking-widest flex items-center justify-center gap-2 shadow-lg shadow-indigo-600/20 transition-all">
            <Plus size={16} /> New Session
          </button>

          <div className="relative mb-6">
            <Search className="absolute left-4 top-1/2 -translate-y-1/2 text-slate-600" size={14} />
            <input 
              type="text" placeholder="Filter Intel..." value={searchQuery} onChange={e => setSearchQuery(e.target.value)}
              className="w-full bg-slate-900 border border-slate-800 rounded-2xl py-3 pl-11 pr-4 text-xs outline-none focus:border-indigo-500 transition-all"
            />
          </div>

          <div className="flex-1 overflow-y-auto space-y-2 pr-2 custom-scrollbar">
            <p className="text-[9px] font-black text-slate-600 uppercase tracking-widest mb-4 ml-2">Archives</p>
            {chats.filter(c => c.title?.toLowerCase().includes(searchQuery.toLowerCase())).map(chat => (
              <div key={chat.id} onClick={() => { setActiveId(chat.id); setSidebarOpen(false); }} className={`group flex items-center justify-between p-4 rounded-xl cursor-pointer transition-all border border-transparent ${activeId === chat.id ? 'bg-slate-800 border-slate-700' : 'hover:bg-slate-800/30 text-slate-500'}`}>
                <div className="flex items-center gap-3 overflow-hidden">
                  <MessageSquare size={14} className={activeId === chat.id ? 'text-indigo-400' : 'text-slate-600'} />
                  <p className="truncate text-[10px] font-bold uppercase tracking-tight">{chat.title || "Untitled"}</p>
                </div>
                <button onClick={(e) => deleteChat(e, chat.id)} className="opacity-0 group-hover:opacity-100 hover:text-red-400 p-1 transition-all"><Trash2 size={12}/></button>
              </div>
            ))}
          </div>

          <button onClick={() => signOut(auth)} className="mt-6 flex items-center justify-between p-4 text-slate-600 hover:text-red-400 text-[10px] font-black uppercase tracking-widest border-t border-slate-800 pt-6">
            Shutdown <LogOut size={14} />
          </button>
        </div>
      </aside>

      {/* Main Area */}
      <main className="flex-1 flex flex-col relative bg-[#020617]">
        <header className="h-20 border-b border-slate-800/30 flex items-center justify-between px-8 bg-[#020617]/50 backdrop-blur-xl z-40">
           <div className="flex items-center gap-4">
              <button className="lg:hidden p-2 text-slate-400" onClick={() => setSidebarOpen(true)}><Menu size={22}/></button>
              <div className="flex items-center gap-2">
                <Fingerprint size={18} className="text-indigo-500" />
                <h2 className="text-[10px] font-black tracking-[0.4em] uppercase text-slate-200">Neural Intelligence Link</h2>
              </div>
           </div>
           <div className="flex items-center gap-4 opacity-50">
              <Cpu size={14} className="animate-spin-slow text-indigo-400" />
              <span className="text-[9px] font-black tracking-widest uppercase">Encryption Active</span>
           </div>
        </header>

        <div className="flex-1 overflow-y-auto p-6 lg:p-10 custom-scrollbar pb-40">
          <div className="max-w-3xl mx-auto space-y-10">
            {messages.length === 0 && (
              <div className="py-20 text-center space-y-8 opacity-20">
                <Waves size={80} className="mx-auto animate-pulse text-indigo-500" />
                <div className="space-y-2">
                  <h3 className="text-xl font-black uppercase tracking-[0.8em]">Awaiting Data</h3>
                  <p className="text-[9px] font-bold uppercase tracking-widest">Initialization ready for query transmission</p>
                </div>
              </div>
            )}
            {messages.map((m, i) => (
              <div key={i} className={`flex flex-col ${m.sender === 'user' ? 'items-end' : 'items-start'}`}>
                <div className={`relative max-w-[85%] p-6 rounded-[2rem] shadow-2xl ${m.sender === 'user' ? 'bg-indigo-600 text-white rounded-tr-none' : 'bg-[#0b0f1a] border border-slate-800 text-slate-200 rounded-tl-none'}`}>
                  <p className="text-sm leading-relaxed font-medium whitespace-pre-wrap">{m.text}</p>
                  {m.sender === 'ai' && (
                    <button onClick={() => { if(isSpeaking === m.id) { window.speechSynthesis.cancel(); setIsSpeaking(null); } else { setIsSpeaking(m.id); const u = new SpeechSynthesisUtterance(m.text); u.onend = () => setIsSpeaking(null); window.speechSynthesis.speak(u); }}} className={`absolute -right-12 bottom-0 p-3 rounded-xl bg-slate-900 border border-slate-800 ${isSpeaking === m.id ? 'text-indigo-400 animate-pulse' : 'text-slate-600'}`}>
                      {isSpeaking === m.id ? <Volume2 size={16}/> : <Play size={16}/>}
                    </button>
                  )}
                </div>
              </div>
            ))}
            <div ref={scrollRef} />
          </div>
        </div>

        {/* Global Input Console */}
        <div className="absolute bottom-0 left-0 right-0 p-6 lg:p-10 pointer-events-none z-50">
          <div className="max-w-3xl mx-auto pointer-events-auto">
            <div className="flex items-center bg-[#0b0f1a]/95 border border-slate-800/80 rounded-[2.5rem] px-5 py-3 shadow-2xl backdrop-blur-3xl focus-within:border-indigo-500/50 transition-all">
              <button className="p-4 text-slate-500 hover:text-indigo-400 transition-colors"><Paperclip size={20}/></button>
              <textarea 
                rows="1" value={input} onChange={e => setInput(e.target.value)}
                onKeyDown={e => {if(e.key === 'Enter' && !e.shiftKey) {e.preventDefault(); handleSendMessage(); }}}
                className="flex-1 bg-transparent border-none outline-none py-4 px-4 text-sm font-bold text-white placeholder:text-slate-700 resize-none"
                placeholder={isListening ? "Listening to neural frequencies..." : "Transmit query..."}
              />
              <button onClick={() => {setIsListening(true); recognitionRef.current?.start();}} className={`p-4 rounded-full transition-all ${isListening ? 'text-red-500 bg-red-500/10 animate-pulse' : 'text-slate-500 hover:text-indigo-400'}`}>
                {isListening ? <MicOff size={20}/> : <Mic size={20}/>}
              </button>
              <button onClick={handleSendMessage} className="ml-2 p-4 bg-indigo-600 text-white rounded-full shadow-lg hover:bg-indigo-500 transition-all">
                {loading ? <Zap size={20} className="animate-spin" /> : <Send size={20}/>}
              </button>
            </div>
          </div>
        </div>
      </main>

      <style dangerouslySetInnerHTML={{ __html: `
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #1e293b; border-radius: 10px; }
        @keyframes spin-slow { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
        .animate-spin-slow { animation: spin-slow 8s linear infinite; }
      `}} />
    </div>
  );
}
